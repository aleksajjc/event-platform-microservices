@using EventPlatform.Models.Lokacija
@model LokacijaCreateViewModel

<h1>Definisite lokaciju</h1>

<form asp-action="Create">
	<div class="mb-3">
		<label for="Naziv" class="form-label">Naziv</label>
		<input type="text" class="form-control" asp-for="Naziv"/>
	</div>
	
	<div class="mb-3">
		<label for="Adresa" class="form-label">Adresa</label>
		<input type="text" class="form-control" asp-for="Adresa"/>
	</div>

	<div class="mb-3">
		<label for="Kapacitet" class="form-label">Kapacitet</label>
		<input type="number" class="form-control" asp-for="Kapacitet"/>
	</div>

	<button type="submit" class="btn btn-primary">Kreiraj</button>
</form>