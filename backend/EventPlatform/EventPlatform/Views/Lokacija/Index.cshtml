@using EventPlatform.Models.Lokacija
@model List<LokacijaViewModel>

<h1>Lokacije</h1>

<a href="@Url.Action("Create","Lokacija")" class="btn btn-primary">Kreiraj novu lokaciju</a>

<table class="table table-striped table-hover mt-3">
	<thead>
		<tr>
			<th>Naziv</th>
			<th>Adresa</th>
			<th>Kapacitet</th>
			<th>Naziv Strucnih dogadjaja</th>
			<th>Datum i vreme održavanja dogadjaja</th>
			<th>Trajanje dogadjaja (h)</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var item in Model)
		{
			<tr>
				<td>@item.Naziv</td>
				<td>@item.Adresa</td>
				<td>@item.Kapacitet</td>
				<td>
					@foreach (var sd in item.OdabraniStrucniDogadjaji)
					{
						<span>@sd.Naziv</span>
				
						<br />
					}
				</td>
				<td>
					@foreach (var sd in item.OdabraniStrucniDogadjaji)
					{
						<span>@sd.DatumVremeOdrzavanja</span>
				
						<br />
					}
				</td>
				<td>
					@foreach (var sd in item.OdabraniStrucniDogadjaji)
					{
						<span>@sd.Trajanje</span>
				
						<br />
					}
				</td>
			</tr>
		}
	</tbody>
</table>