@model EventPlatform.Models.Dogadjaji.DogadjajViewModel

@{
    ViewData["Title"] = "Detalji Događaja";
}

<div class="container mt-5">
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-danger shadow-sm py-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-shield-lock-fill fs-1 me-3 text-danger"></i>
                <div>
                    <h4 class="mb-1">Servis privremeno nedostupan</h4>
                    <p class="mb-0">@ViewBag.Message</p>
                </div>
            </div>
            <hr class="mt-3">
            <a asp-action="Index" class="btn btn-outline-danger">Povratak na listu</a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a asp-action="Index">Događaji</a></li>
                        <li class="breadcrumb-item active">@Model.Naziv</li>
                    </ol>
                </nav>
                <h1 class="display-5 fw-bold text-primary mb-0">@Model.Naziv</h1>
            </div>
            <span class="badge bg-primary p-2 fs-6">@Model.TipDogadjaja?.NazivTipa</span>
        </div>

        <div class="row g-4">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold border-start border-primary border-4 ps-3 mb-3">Agenda</h5>
                        <div class="p-3 bg-light rounded" style="white-space: pre-line; line-height: 1.7;">
                            @Model.Agenda
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">Predavači na ovom događaju</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Titula</th>
                                        <th>Ime i Prezime</th>
                                        <th>Oblast stručnosti</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.Predavaci)
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">@p.Titula</span></td>
                                            <td class="fw-bold">@p.Ime @p.Prezime</td>
                                            <td class="text-muted">@p.OblastStrucnosti</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-primary text-white border-0 shadow mb-4" style="border-radius: 15px;">
                    <div class="card-body p-4 text-center">
                        <p class="mb-1 opacity-75 small text-uppercase">Cena kotizacije</p>
                        <h2 class="display-6 fw-bold mb-0">@Model.CenaKotizacije.ToString("N2") <small class="fs-5">RSD</small></h2>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-calendar3 fs-4 text-primary me-3"></i>
                            <div>
                                <small class="text-muted d-block">Datum i vreme</small>
                                <span class="fw-bold">@Model.DatumVremeOdrzavanja.ToString("dd.MM.yyyy HH:mm")h</span>
                            </div>
                        </div>
                        <hr class="opacity-10">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-geo-alt fs-4 text-primary me-3"></i>
                            <div>
                                <small class="text-muted d-block">Lokacija</small>
                                <span class="fw-bold">@Model.Lokacija?.Naziv</span>
                                <small class="text-muted d-block">@Model.Lokacija?.Adresa</small>
                            </div>
                        </div>
                        <hr class="opacity-10">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-clock fs-4 text-primary me-3"></i>
                            <div>
                                <small class="text-muted d-block">Trajanje i mesta</small>
                                <span class="fw-bold">@Model.Trajanje h </span>
                                <small class="text-muted d-block">Kapacitet: @Model.Lokacija?.Kapacitet mesta</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary py-2 rounded-3">Povratak na listu</a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
