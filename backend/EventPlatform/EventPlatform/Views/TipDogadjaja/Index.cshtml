@using EventPlatform.Models.TipDogadjaja
@model List<TipDogadjajaViewModel>

<h1>Tipovi događaja</h1>

<a href="@Url.Action("Create","TipDogadjaja")" class="btn btn-primary">Kreiraj novi tip događaja</a>

<table class="table table-striped table-hover mt-3">
    <thead>
        <tr>
            <th>Naziv tipa</th>
            <th>Naziv događaja</th>
            <th>Datum održavanja</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.NazivTipa</td>
                <td>
                    @if (item.StrucniDogadjaji != null && item.StrucniDogadjaji.Any())
                    {
                        @foreach (var sd in item.StrucniDogadjaji)
                        {
                            <span>@sd.Naziv</span>
                            <br />
                        }
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
                <td>
                    @if (item.StrucniDogadjaji != null && item.StrucniDogadjaji.Any())
                    {
                        @foreach (var sd in item.StrucniDogadjaji)
                        {
                            <span>@sd.DatumVremeOdrzavanja</span>
                            <br />
                        }
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("Edit","TipDogadjaja",new {id = item.TipDogadjajaID})" 
                           class="btn btn-primary btn-sm">Izmeni</a>
                        
                        @if (item.StrucniDogadjaji != null && item.StrucniDogadjaji.Any())
                        {
                            <button class="btn btn-secondary btn-sm" disabled title="Nije moguće obrisati tip sa događajima">
                                Obriši
                            </button>
                        }
                        else
                        {
                            <form asp-action="Delete" asp-route-id="@item.TipDogadjajaID" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Da li ste sigurni?')">
                                    Obriši
                                </button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
