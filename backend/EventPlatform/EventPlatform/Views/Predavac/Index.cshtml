@using EventPlatform.Models.Predavac
@model List<PredavacViewModel>

<h1>Predavači</h1>

<a href="@Url.Action("Create","Predavac")" class="btn btn-primary">Kreiraj novog predavača </a>

<table class="table table-striped table-hover mt-3">
	<thead>
		<tr>
			<th>Ime</th>
			<th>Prezime</th>
			<th>Titula</th>
			<th>Oblast stručnosti</th>
			<th>Stručni dogadjaj</th>
			<th>Datum i vreme održavanja dogadjaja</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var item in Model)
		{
			<tr>
				<td>@item.Ime</td>
				<td>@item.Prezime</td>
				<td>@item.Titula</td>
				<td>@item.OblastStrucnosti</td>
				<td>
					@foreach(var p in item.OdabraniStrucniDogadjaji)
					{
						<span>@p.Naziv</span>
						<br />
					}
				</td>
				<td>
					@foreach (var p in item.OdabraniStrucniDogadjaji)
					{
						<span>@p.DatumVremeOdrzavanja</span>
						<br />
					}
				</td>
				<td>
					<a href="@Url.Action("Edit","Predavac", new {Id = item.PredavacID})" 
					class="btn btn-primary btn-sm">Izmeni</a>
				</td>
				<td>
					@if (item.OdabraniStrucniDogadjaji.Any())
					{
						<button class="btn btn-secondary btn-sm" disabled title="Nije moguće obrisati predavača sa događajima">
							Obriši
						</button>
					}
					else
					{
							<form asp-action="Delete" asp-route-id="@item.PredavacID" method="post" style="display:inline;">
								<button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Da li ste sigurni?')">
									Obriši
								</button>
							</form>
					}
				</td>
			</tr>
		}
	</tbody>
</table>